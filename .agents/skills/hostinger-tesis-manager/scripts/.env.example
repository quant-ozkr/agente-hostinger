# Variables de entorno para el agente MCP de Hostinger VPS
# Copie este archivo a .env y complete los valores reales

# Dirección IP del VPS de Hostinger
HOSTINGER_IP=your_vps_ip_here

# Puerto SSH personalizado (recomendado: 2222 para mayor seguridad)
HOSTINGER_PORT=2222

# Usuario para conectarse al VPS (debe ser un usuario sudo limitado)
HOSTINGER_USER=tesis

# Ruta absoluta a la llave privada SSH para autenticación
# Ejemplo: /home/tuusuario/.ssh/id_rsa
SSH_KEY_PATH=/path/to/your/private/key

# NOTA: La autenticación por contraseña está DESACTIVADA por razones de seguridad.
# Solo se permite autenticación mediante llave SSH.
# Si necesita usar contraseña (NO RECOMENDADO), descomente la siguiente línea:
# HOSTINGER_PASSWORD=your_password_here